{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    "opener:allow-open-path",
    "dialog:default",
    "fs:read-all",
    "fs:write-all",
    "fs:allow-open",
    "fs:allow-write",
    "fs:allow-read",
    "fs:allow-rename",
    "fs:allow-mkdir",
    "fs:allow-remove",
    {
      "identifier":"shell:allow-execute",
      "allow": [
        {
          "name": "exec-sh",
          "cmd": "sh",
          "args": [
            "-c",
            {
              "validator": "*"
            }
          ]
        }
      ]
    },
    {
      "identifier":"opener:allow-open-url",
      "allow": [
        {
          "url":"https://*"
        }
      ]
    },
    {
      "identifier":"opener:allow-open-path",
      "allow": [
        {
          "path":"**"
        }
      ]
    },
    {
      "identifier": "fs:allow-read-file",
      "allow": [
        {
          "path": "**"
        }
      ]
    },
    {
      "identifier": "fs:allow-write-file",
      "allow": [
        {
          "path": "**"
        }
      ]
    },
    {
      "identifier":"fs:scope",
      "allow": [
        {
          "path": "**"
        }
      ]
    }
  ]
}
