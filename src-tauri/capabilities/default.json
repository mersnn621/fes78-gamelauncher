{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    "dialog:default",
    {
      "identifier":"shell:allow-execute",
      "allow": [
        {
          "name": "exec-sh",
          "cmd": "sh",
          "args": [
            "-c",
            {
              "validator": "*"
            }
          ]
        }
      ]
    },
    {
      "identifier":"opener:allow-open-url",
      "allow": [
        {
          "url":"https://*"
        }
      ]
    }
  ]
}
